#include <stdio.h>
#include <string.h>

int main() {

    char texte[100];
    int i;

    printf("Entrez un texte qu´on doit chiffré en MAJUSCULE : ");
    scanf("%s", texte);

    for(i = 0; i < strlen(texte); i++) {

        if(texte[i] >= 'A' && texte[i] <= 'Z') {

            texte[i] = texte[i] + 3; // Chiffrement de César (+3)

            if(texte[i] > 'Z') {
                texte[i] = texte[i] - 26;
            }
        }
    }

    printf("Texte chiffre : %s\n", texte);

    return 0;
}
