#include <stdio.h>
#include <string.h>

int main() {

    char texte[100];
    int i;

    printf("Entrez le texte chiffré : ");
    scanf("%s", texte);

    for(i = 0; i < strlen(texte); i++) {

        if(texte[i] >= 'A' && texte[i] <= 'Z') {

            texte[i] = texte[i] - 3; // Déchiffrement de César (+3)

            if(texte[i] < 'A') {
                texte[i] = texte[i] + 26;
            }
        }
    }

    printf("Texte dechiffré : %s\n", texte);

    return 0;
}
